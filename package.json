{
  "name": "devwatch",
  "displayName": "DevWatch",
  "description": "Real-time process and port management for VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devwatch-explorer",
          "title": "DevWatch",
          "icon": "$(server-process)"
        }
      ]
    },
    "views": {
      "devwatch-explorer": [
        {
          "id": "devwatch.processTree",
          "name": "Processes",
          "icon": "$(server-process)",
          "contextualTitle": "DevWatch Processes"
        },
        {
          "id": "devwatch.portTree",
          "name": "Ports",
          "icon": "$(plug)",
          "contextualTitle": "DevWatch Ports"
        }
      ]
    },
    "commands": [
      {
        "command": "devwatch.showProcesses",
        "title": "DevWatch: Show Processes"
      },
      {
        "command": "devwatch.showPorts",
        "title": "DevWatch: Show Ports"
      },
      {
        "command": "devwatch.refresh",
        "title": "DevWatch: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "devwatch.toggleInfraProcesses",
        "title": "DevWatch: Toggle Infrastructure Processes"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "devwatch.refresh",
          "when": "view == devwatch.processTree || view == devwatch.portTree",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "DevWatch",
      "properties": {
        "devwatch.pollingPreset": {
          "type": "string",
          "enum": ["fast", "normal", "battery", "custom"],
          "enumDescriptions": [
            "Fast: 1s visible / 10s hidden",
            "Normal: 3s visible / 30s hidden (default)",
            "Battery Saver: 10s visible / 60s hidden",
            "Custom: Use pollingVisibleMs and pollingHiddenMs"
          ],
          "default": "normal",
          "description": "Polling interval preset for resource monitoring"
        },
        "devwatch.pollingVisibleMs": {
          "type": "number",
          "default": 3000,
          "minimum": 500,
          "maximum": 60000,
          "description": "Custom polling interval when view is visible (ms). Only used when preset is 'custom'."
        },
        "devwatch.pollingHiddenMs": {
          "type": "number",
          "default": 30000,
          "minimum": 5000,
          "maximum": 300000,
          "description": "Custom polling interval when view is hidden (ms). Only used when preset is 'custom'."
        },
        "devwatch.customPortLabels": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "port": { "type": "number", "description": "Port number" },
              "label": { "type": "string", "description": "Custom label for this port" }
            },
            "required": ["port", "label"]
          },
          "default": [],
          "description": "Custom port labels. These override built-in labels."
        },
        "devwatch.showInfraProcesses": {
          "type": "boolean",
          "default": false,
          "description": "Show infrastructure processes (shells, VS Code helpers) in the process tree"
        }
      }
    }
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Process monitoring is view-only in untrusted workspaces"
    }
  },
  "scripts": {
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "compile": "tsc -p ./",
    "lint": "eslint src",
    "test": "vitest run",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.24.0",
    "eslint": "^8.56.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
