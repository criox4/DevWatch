{
  "name": "devwatch",
  "displayName": "DevWatch",
  "description": "Real-time process and port management for VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devwatch-explorer",
          "title": "DevWatch",
          "icon": "$(server-process)"
        }
      ]
    },
    "views": {
      "devwatch-explorer": [
        {
          "id": "devwatch.processTree",
          "name": "Processes",
          "icon": "$(server-process)",
          "contextualTitle": "DevWatch Processes"
        },
        {
          "id": "devwatch.portTree",
          "name": "Ports",
          "icon": "$(plug)",
          "contextualTitle": "DevWatch Ports"
        },
        {
          "id": "devwatch.containerTree",
          "name": "Containers",
          "icon": "$(container)",
          "contextualTitle": "DevWatch Containers"
        }
      ]
    },
    "commands": [
      {
        "command": "devwatch.showProcesses",
        "title": "Show Processes",
        "category": "DevWatch"
      },
      {
        "command": "devwatch.showPorts",
        "title": "Show Ports",
        "category": "DevWatch"
      },
      {
        "command": "devwatch.refresh",
        "title": "Refresh",
        "category": "DevWatch",
        "icon": "$(refresh)"
      },
      {
        "command": "devwatch.toggleInfraProcesses",
        "title": "Toggle Infrastructure Processes",
        "category": "DevWatch"
      },
      {
        "command": "devwatch.killProcess",
        "title": "Kill Process",
        "category": "DevWatch",
        "icon": "$(close)"
      },
      {
        "command": "devwatch.forceKillProcess",
        "title": "Force Kill Process",
        "category": "DevWatch",
        "icon": "$(flame)"
      },
      {
        "command": "devwatch.killProcessTree",
        "title": "Kill Process Tree",
        "category": "DevWatch",
        "icon": "$(trash)"
      },
      {
        "command": "devwatch.restartProcess",
        "title": "Restart Process",
        "category": "DevWatch",
        "icon": "$(debug-restart)"
      },
      {
        "command": "devwatch.copyPid",
        "title": "Copy PID",
        "category": "DevWatch"
      },
      {
        "command": "devwatch.copyCommand",
        "title": "Copy Command",
        "category": "DevWatch"
      },
      {
        "command": "devwatch.copyProcessJson",
        "title": "Copy Process as JSON",
        "category": "DevWatch"
      },
      {
        "command": "devwatch.pinProcess",
        "title": "Pin Process",
        "category": "DevWatch",
        "icon": "$(pin)"
      },
      {
        "command": "devwatch.unpinProcess",
        "title": "Unpin Process",
        "category": "DevWatch",
        "icon": "$(pinned)"
      },
      {
        "command": "devwatch.copyPort",
        "title": "Copy Port Number",
        "category": "DevWatch"
      },
      {
        "command": "devwatch.copyPortJson",
        "title": "Copy Port as JSON",
        "category": "DevWatch"
      },
      {
        "command": "devwatch.openInBrowser",
        "title": "Open in Browser",
        "category": "DevWatch",
        "icon": "$(globe)"
      },
      {
        "command": "devwatch.pinPort",
        "title": "Pin Port",
        "category": "DevWatch",
        "icon": "$(pin)"
      },
      {
        "command": "devwatch.unpinPort",
        "title": "Unpin Port",
        "category": "DevWatch",
        "icon": "$(pinned)"
      },
      {
        "command": "devwatch.viewInHistory",
        "title": "View in History",
        "category": "DevWatch",
        "icon": "$(history)"
      },
      {
        "command": "devwatch.filterProcesses",
        "title": "Filter Processes",
        "category": "DevWatch",
        "icon": "$(filter)"
      },
      {
        "command": "devwatch.filterPorts",
        "title": "Filter Ports",
        "category": "DevWatch",
        "icon": "$(filter)"
      },
      {
        "command": "devwatch.searchProcesses",
        "title": "Search Processes",
        "category": "DevWatch",
        "icon": "$(search)"
      },
      {
        "command": "devwatch.searchPorts",
        "title": "Search Ports",
        "category": "DevWatch",
        "icon": "$(search)"
      },
      {
        "command": "devwatch.openOverview",
        "title": "Open Overview",
        "category": "DevWatch",
        "icon": "$(dashboard)"
      },
      {
        "command": "devwatch.quickKill",
        "title": "Quick Kill Process",
        "category": "DevWatch",
        "icon": "$(close)"
      },
      {
        "command": "devwatch.restartLast",
        "title": "Restart Last Killed",
        "category": "DevWatch",
        "icon": "$(debug-restart)"
      },
      {
        "command": "devwatch.freePort",
        "title": "Free Port",
        "category": "DevWatch",
        "icon": "$(close)"
      },
      {
        "command": "devwatch.bulkKillWorkspace",
        "title": "Kill All Workspace Processes",
        "category": "DevWatch"
      },
      {
        "command": "devwatch.bulkKillOnPort",
        "title": "Kill All Processes on Port",
        "category": "DevWatch"
      },
      {
        "command": "devwatch.toggleAutoRestart",
        "title": "Toggle Auto-Restart",
        "category": "DevWatch",
        "icon": "$(sync)"
      },
      {
        "command": "devwatch.bulkKillOrphans",
        "title": "Clean Up Orphaned Processes",
        "category": "DevWatch"
      },
      {
        "command": "devwatch.openHistory",
        "title": "Open History",
        "category": "DevWatch",
        "icon": "$(history)"
      },
      {
        "command": "devwatch.clearHistory",
        "title": "Clear History",
        "category": "DevWatch"
      },
      {
        "command": "devwatch.stopContainer",
        "title": "Stop Container",
        "category": "DevWatch",
        "icon": "$(debug-stop)"
      },
      {
        "command": "devwatch.killContainer",
        "title": "Kill Container",
        "category": "DevWatch",
        "icon": "$(flame)"
      },
      {
        "command": "devwatch.stopComposeProject",
        "title": "Stop Compose Project",
        "category": "DevWatch",
        "icon": "$(debug-stop)"
      },
      {
        "command": "devwatch.refreshContainers",
        "title": "Refresh Containers",
        "category": "DevWatch",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "devwatch.refresh",
          "when": "view == devwatch.processTree",
          "group": "navigation@1"
        },
        {
          "command": "devwatch.filterProcesses",
          "when": "view == devwatch.processTree",
          "group": "navigation@2"
        },
        {
          "command": "devwatch.searchProcesses",
          "when": "view == devwatch.processTree",
          "group": "navigation@3"
        },
        {
          "command": "devwatch.openHistory",
          "when": "view == devwatch.processTree",
          "group": "navigation@4"
        },
        {
          "command": "devwatch.refresh",
          "when": "view == devwatch.portTree",
          "group": "navigation@1"
        },
        {
          "command": "devwatch.filterPorts",
          "when": "view == devwatch.portTree",
          "group": "navigation@2"
        },
        {
          "command": "devwatch.searchPorts",
          "when": "view == devwatch.portTree",
          "group": "navigation@3"
        },
        {
          "command": "devwatch.openHistory",
          "when": "view == devwatch.portTree",
          "group": "navigation@4"
        },
        {
          "command": "devwatch.refreshContainers",
          "when": "view == devwatch.containerTree",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "devwatch.killProcess",
          "when": "view == devwatch.processTree && viewItem =~ /^(pinned)?process$/",
          "group": "1_actions@1"
        },
        {
          "command": "devwatch.forceKillProcess",
          "when": "view == devwatch.processTree && viewItem =~ /^(pinned)?process$/",
          "group": "1_actions@2"
        },
        {
          "command": "devwatch.killProcessTree",
          "when": "view == devwatch.processTree && viewItem =~ /^(pinned)?process$/",
          "group": "1_actions@3"
        },
        {
          "command": "devwatch.restartProcess",
          "when": "view == devwatch.processTree && viewItem =~ /^(pinned)?process$/",
          "group": "1_actions@4"
        },
        {
          "command": "devwatch.toggleAutoRestart",
          "when": "view == devwatch.processTree && viewItem =~ /^(pinned)?process$/",
          "group": "1_actions@5"
        },
        {
          "command": "devwatch.copyPid",
          "when": "view == devwatch.processTree && viewItem =~ /^(pinned)?process$/",
          "group": "2_copy@1"
        },
        {
          "command": "devwatch.copyCommand",
          "when": "view == devwatch.processTree && viewItem =~ /^(pinned)?process$/",
          "group": "2_copy@2"
        },
        {
          "command": "devwatch.copyProcessJson",
          "when": "view == devwatch.processTree && viewItem =~ /^(pinned)?process$/",
          "group": "2_copy@3"
        },
        {
          "command": "devwatch.pinProcess",
          "when": "view == devwatch.processTree && viewItem == process",
          "group": "3_pin@1"
        },
        {
          "command": "devwatch.unpinProcess",
          "when": "view == devwatch.processTree && viewItem == pinnedProcess",
          "group": "3_pin@1"
        },
        {
          "command": "devwatch.viewInHistory",
          "when": "view == devwatch.processTree && viewItem =~ /^(pinned)?process$/",
          "group": "4_other@1"
        },
        {
          "command": "devwatch.freePort",
          "when": "view == devwatch.portTree && viewItem =~ /^(pinned)?port$/",
          "group": "1_actions@0"
        },
        {
          "command": "devwatch.openInBrowser",
          "when": "view == devwatch.portTree && viewItem =~ /^(pinned)?port$/",
          "group": "1_actions@1"
        },
        {
          "command": "devwatch.copyPort",
          "when": "view == devwatch.portTree && viewItem =~ /^(pinned)?port$/",
          "group": "2_copy@1"
        },
        {
          "command": "devwatch.copyPortJson",
          "when": "view == devwatch.portTree && viewItem =~ /^(pinned)?port$/",
          "group": "2_copy@2"
        },
        {
          "command": "devwatch.pinPort",
          "when": "view == devwatch.portTree && viewItem == port",
          "group": "3_pin@1"
        },
        {
          "command": "devwatch.unpinPort",
          "when": "view == devwatch.portTree && viewItem == pinnedPort",
          "group": "3_pin@1"
        },
        {
          "command": "devwatch.viewInHistory",
          "when": "view == devwatch.portTree && viewItem =~ /^(pinned)?port$/",
          "group": "4_other@1"
        },
        {
          "command": "devwatch.stopContainer",
          "when": "view == devwatch.containerTree && viewItem == container",
          "group": "1_actions@1"
        },
        {
          "command": "devwatch.killContainer",
          "when": "view == devwatch.containerTree && viewItem == container",
          "group": "1_actions@2"
        },
        {
          "command": "devwatch.stopComposeProject",
          "when": "view == devwatch.containerTree && viewItem == composeProject",
          "group": "1_actions@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "devwatch.quickKill",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k"
      },
      {
        "command": "devwatch.restartLast",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      },
      {
        "command": "devwatch.openHistory",
        "key": "ctrl+shift+h",
        "mac": "cmd+shift+h"
      }
    ],
    "configuration": {
      "title": "DevWatch",
      "properties": {
        "devwatch.pollingPreset": {
          "type": "string",
          "enum": [
            "fast",
            "normal",
            "battery",
            "custom"
          ],
          "enumDescriptions": [
            "Fast: 1s visible / 10s hidden",
            "Normal: 3s visible / 30s hidden (default)",
            "Battery Saver: 10s visible / 60s hidden",
            "Custom: Use pollingVisibleMs and pollingHiddenMs"
          ],
          "default": "normal",
          "description": "Polling interval preset for resource monitoring"
        },
        "devwatch.pollingVisibleMs": {
          "type": "number",
          "default": 3000,
          "minimum": 500,
          "maximum": 60000,
          "description": "Custom polling interval when view is visible (ms). Only used when preset is 'custom'."
        },
        "devwatch.pollingHiddenMs": {
          "type": "number",
          "default": 30000,
          "minimum": 5000,
          "maximum": 300000,
          "description": "Custom polling interval when view is hidden (ms). Only used when preset is 'custom'."
        },
        "devwatch.customPortLabels": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "port": {
                "type": "number",
                "description": "Port number"
              },
              "label": {
                "type": "string",
                "description": "Custom label for this port"
              }
            },
            "required": [
              "port",
              "label"
            ]
          },
          "default": [],
          "description": "Custom port labels. These override built-in labels."
        },
        "devwatch.showInfraProcesses": {
          "type": "boolean",
          "default": false,
          "description": "Show infrastructure processes (shells, VS Code helpers) in the process tree"
        },
        "devwatch.skipKillConfirmation": {
          "type": "boolean",
          "default": false,
          "description": "Skip confirmation dialogs for force-kill and kill-tree operations"
        },
        "devwatch.alertThresholdCpu": {
          "type": "number",
          "default": 80,
          "minimum": 10,
          "maximum": 100,
          "description": "CPU usage threshold (%) for alerts. Processes exceeding this for 2+ consecutive polls trigger a warning."
        },
        "devwatch.alertThresholdMemoryMB": {
          "type": "number",
          "default": 500,
          "minimum": 50,
          "maximum": 16384,
          "description": "Memory usage threshold (MB) for alerts. Processes exceeding this for 2+ consecutive polls trigger a warning."
        },
        "devwatch.notificationVerbosity": {
          "type": "string",
          "enum": [
            "minimal",
            "moderate",
            "comprehensive"
          ],
          "enumDescriptions": [
            "Critical events only: crashes, critical resource alerts (>90% CPU, >1GB RAM)",
            "Important events: crashes, thresholds, orphans, port conflicts",
            "All events: includes new port opened notifications"
          ],
          "default": "minimal",
          "description": "Controls which monitoring events trigger notifications"
        },
        "devwatch.alertCooldownSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "maximum": 300,
          "description": "Cooldown period (seconds) between repeated notifications of the same type. Critical alerts bypass this."
        },
        "devwatch.historyRetentionDays": {
          "type": "number",
          "default": 14,
          "minimum": 1,
          "maximum": 365,
          "description": "Number of days to retain history log files. Rotated files older than this are automatically deleted."
        },
        "devwatch.sessionSummary.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show a session summary notification when VS Code closes if anomalies (crashes, threshold breaches) were detected."
        },
        "devwatch.mcp.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable MCP (Model Context Protocol) server integration for Claude Code. Provides DevWatch tools to Claude via MCP."
        },
        "devwatch.docker.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Docker container monitoring and management. Requires Docker to be installed and running."
        }
      }
    }
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Process monitoring is view-only in untrusted workspaces"
    }
  },
  "scripts": {
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "compile": "tsc -p ./",
    "lint": "eslint src",
    "test": "vitest run",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.24.0",
    "eslint": "^8.56.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "dockerode": "^4.0.9",
    "exponential-backoff": "^3.1.3",
    "tree-kill": "^1.2.2",
    "zod": "^4.3.6"
  }
}
